# ==============================================
# Laravel / PHP sensitive files
# ==============================================
.env
.env.*
!.env.example
!.env.example.copy
auth.json
*.key
*.pem
_ide_helper.php
_ide_helper_models.php
.phpactor.json
.phpunit.result.cache

# ==============================================
# Laravel framework directories
# ==============================================
/vendor
/node_modules
/bootstrap/cache
/storage/*.key
/storage/pail
/storage/logs/*.log
!/storage/logs/.gitignore
!/storage/app/.gitignore
!/storage/app/public/.gitignore
!/storage/framework/.gitignore
!/storage/framework/cache/.gitignore
!/storage/framework/cache/data/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/testing/.gitignore
!/storage/framework/views/.gitignore

# ==============================================
# Database files
# ==============================================
*.sqlite
*.sqlite3
database/*.sqlite
database/*.sqlite3
database/database.sqlite

# ==============================================
# Build & compiled assets
# ==============================================
/public/build
/public/fonts-manifest.dev.json
/public/hot
/public/storage
*.blade.php

# ==============================================
# IDE & editor files
# ==============================================
/.idea
/.vscode
!/.vscode/settings.json
!/.vscode/extensions.json
!/.vscode/*.code-snippets
/.cursor/
/.cursor/*
/.nova
/.nova/*
/.zed
/.zed/*
/.phpunit.cache
/.codex
/.codex/*

# ==============================================
# OS & system files
# ==============================================
.DS_Store
Thumbs.db
*.log
*.swp
*.swo
*~

# ==============================================
# Deployment & infrastructure
# ==============================================
Homestead.json
Homestead.yaml
deploy.rake

# ==============================================
# Documentation & misc
# ==============================================
/docs
*.md
!README.md
