APP_NAME=SIPRAKAR
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------
# Database
# ---------------------------------------------
# Untuk development: SQLite (file database sudah ada)
# Untuk production: gunakan MySQL/PostgreSQL
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=siprakar
# DB_USERNAME=root
# DB_PASSWORD=

# ---------------------------------------------
# Session, Cache & Queue
# ---------------------------------------------
# Untuk production: ganti ke redis
# ---------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file

# Queue: sync (development) | redis (production)
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------------------------------------------
# Redis (untuk Session, Cache & Queue di Production)
# ---------------------------------------------
# Install predis/predis: composer require predis/predis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------
# Mail
# ---------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------
# WhatsApp Gateway (Fonnte)
# ---------------------------------------------
WHATSAPP_GATEWAY_URL=https://api.fonnte.com/send
WHATSAPP_GATEWAY_TOKEN=ISI_TOKEN_FONNTE_KAMU
WHATSAPP_DEFAULT_COUNTRY_CODE=62

# ---------------------------------------------
# AWS (Optional - untuk storage S3)
# ---------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"


# ---------------------------------------------
# Cloudflare Turnstile CAPTCHA
# Isi dari Cloudflare Dashboard > Turnstile.
# Set TURNSTILE_ENABLED=true jika Site Key dan Secret Key sudah valid.
# ---------------------------------------------
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Nomor WhatsApp akun demo cabang Viktor.
